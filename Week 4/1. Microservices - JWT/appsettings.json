{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // ---------------------------------------------------------------------------
  // JWT settings from the exercise sheet. The token-CREATING side
  // (AuthController) and the token-VALIDATING side (Program.cs) both read these
  // values, so they always stay in sync.
  //
  // Signing-key note: the sheet uses "ThisIsASecretKeyForJwtToken" (27 bytes).
  // Modern Microsoft.IdentityModel requires an HMAC-SHA256 key of >= 256 bits
  // (32 bytes) or it throws IDX10720 at runtime, so the key below is padded to a
  // valid length while keeping the same spirit. In a real microservice this
  // belongs in a secret store / environment variable, never in source control.
  // ---------------------------------------------------------------------------
  "Jwt": {
    "Key": "ThisIsASecretKeyForJwtToken_min_32_bytes!!",
    "Issuer": "MyAuthServer",
    "Audience": "MyApiUsers",
    "DurationInMinutes": 60
  }
}
